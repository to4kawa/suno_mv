{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Suno MV Maker",
  "version": "0.1.0",
  "identifier": "com.example.suno-mv-maker",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "npm run serve",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Suno MV Maker",
        "width": 1080,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
